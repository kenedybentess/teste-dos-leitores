<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Etiquetas - Leitores PRO</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Segoe UI,Tahoma,sans-serif}
body{background:#f4f6f9;padding:20px}
.header-etq{background:linear-gradient(135deg,#0d6efd,#1e88e5);color:white;padding:25px;border-radius:15px;margin-bottom:30px}
.etiqueta-preview{border:3px dashed #0d6efd;background:white;padding:20px;border-radius:10px;font-family:monospace;font-size:14px;min-height:200px}
.zpl-code{background:#1e1e1e;color:#d4d4d4;padding:15px;border-radius:8px;font-family:'Courier New',monospace;font-size:12px;overflow-x:auto;white-space:pre}
.table-etq{background:white;border-radius:10px;overflow:hidden;box-shadow:0 5px 15px rgba(0,0,0,.08)}
.table-etq thead{background:#0d6efd;color:white}
.badge-teste{background:#198754}
</style>
</head>
<body>
<div class="container-fluid">
    <div class="header-etq">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2><i class="bi bi-printer"></i> Geração de Etiquetas ZPL</h2>
                <p class="mb-0">Imprime etiqueta dos leitores testados e aprovados</p>
            </div>
            <a href="index.html" class="btn btn-light"><i class="bi bi-arrow-left"></i> Dashboard</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-list-check"></i> Testes Aprovados Hoje</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label>Filtrar por Produto</label>
                        <select id="filtroProduto" class="form-select" onchange="carregarTestesAprovados()">
                            <option value="">Todos os produtos</option>
                        </select>
                    </div>
                    <div class="table-etq">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="checkAll" onchange="marcarTodos()"></th>
                                    <th>Série</th>
                                    <th>Produto</th>
                                    <th>Hora</th>
                                </tr>
                            </thead>
                            <tbody id="tabelaTestes"></tbody>
                        </table>
                    </div>
                    <button class="btn btn-success w-100 mt-3" onclick="gerarEtiquetasSelecionadas()">
                        <i class="bi bi-printer"></i> Gerar Etiquetas Selecionadas
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-eye"></i> Preview da Etiqueta</h5>
                </div>
                <div class="card-body">
                    <div class="etiqueta-preview mb-3" id="previewEtiqueta">
                        <div class="text-center text-muted">
                            <i class="bi bi-upc-scan" style="font-size:60px"></i>
                            <p class="mt-3">Selecione um teste ao lado para visualizar</p>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" onclick="imprimirEtiqueta()" id="btnImprimir" disabled>
                            <i class="bi bi-printer-fill"></i> Imprimir na Zebra
                        </button>
                        <button class="btn btn-secondary" onclick="baixarZPL()" id="btnBaixar" disabled>
                            <i class="bi bi-download"></i> Baixar arquivo.ZPL
                        </button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-code-slash"></i> Código ZPL</h6>
                </div>
                <div class="card-body">
                    <div class="zpl-code" id="codigoZPL">^XA
^FO50,50^A0N,40,40^FDLEITORES PRO^FS
^FO50,100^A0N,30,30^FDAguardando teste...^FS
^XZ</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
let testesSelecionados = [];
let zplAtual = '';

if(!localStorage.getItem('testes')) localStorage.setItem('testes',JSON.stringify([]));
if(!localStorage.getItem('produtos')) localStorage.setItem('produtos',JSON.stringify([]));

document.addEventListener('DOMContentLoaded', () => {
    carregarProdutos();
    carregarTestesAprovados();
});

function carregarProdutos(){
    const produtos = JSON.parse(localStorage.getItem('produtos'));
    const select = document.getElementById('filtroProduto');
    select.innerHTML = '<option value="">Todos os produtos</option>' + 
        produtos.map(p => `<option value="${p.codigo}">${p.codigo} - ${p.nome}</option>`).join('');
}

function carregarTestesAprovados(){
    const filtroProduto = document.getElementById('filtroProduto').value;
    const hoje = new Date().toLocaleDateString('pt-BR');
    let testes = JSON.parse(localStorage.getItem('testes'));
    
    // Filtra só APROVADOS de hoje
    testes = testes.filter(t => {
        const dataTeste = new Date(t.data).toLocaleDateString('pt-BR');
        const aprovado = t.resultado === 'APROVADO';
        const hojeMesmo = dataTeste === hoje;
        const produtoOk =!filtroProduto || t.produtoCodigo === filtroProduto;
        return aprovado && hojeMesmo && produtoOk;
    });
    
    const tbody = document.getElementById('tabelaTestes');
    tbody.innerHTML = testes.length === 0? 
        '<tr><td colspan="4" class="text-center text-muted">Nenhum teste aprovado hoje</td></tr>' :
        testes.map(t => {
            const hora = new Date(t.data).toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});
            return `<tr>
                <td><input type="checkbox" class="check-teste" value="${t.id}" onchange="atualizarSelecao()"></td>
                <td><strong>${t.serie}</strong></td>
                <td>${t.produtoCodigo}</td>
                <td>${hora}</td>
            </tr>`
        }).join('');
}

function marcarTodos(){
    const checkAll = document.getElementById('checkAll').checked;
    document.querySelectorAll('.check-teste').forEach(cb => cb.checked = checkAll);
    atualizarSelecao();
}

function atualizarSelecao(){
    const checkboxes = document.querySelectorAll('.check-teste:checked');
    const ids = Array.from(checkboxes).map(cb => cb.value);
    testesSelecionados = JSON.parse(localStorage.getItem('testes')).filter(t => ids.includes(t.id));
    
    if(testesSelecionados.length === 1){
        gerarPreview(testesSelecionados[0]);
        document.getElementById('btnImprimir').disabled = false;
        document.getElementById('btnBaixar').disabled = false;
    } else {
        document.getElementById('previewEtiqueta').innerHTML = `
            <div class="text-center text-muted">
                <i class="bi bi-check2-square" style="font-size:60px"></i>
                <p class="mt-3">${testesSelecionados.length} teste(s) selecionado(s)</p>
            </div>`;
        document.getElementById('btnImprimir').disabled = testesSelecionados.length === 0;
        document.getElementById('btnBaixar').disabled = testesSelecionados.length === 0;
    }
}

function gerarPreview(teste){
    const data = new Date(teste.data).toLocaleDateString('pt-BR');
    const hora = new Date(teste.data).toLocaleTimeString('pt-BR');
    
    document.getElementById('previewEtiqueta').innerHTML = `
        <div style="border:2px solid #000;padding:15px;font-family:Arial">
            <div style="text-align:center;font-weight:bold;font-size:18px;margin-bottom:10px">LEITORES PRO</div>
            <div style="font-size:14px;line-height:1.8">
                <strong>Produto:</strong> ${teste.produtoCodigo}<br>
                <strong>Modelo:</strong> ${teste.modelo}<br>
                <strong>Série:</strong> ${teste.serie}<br>
                <strong>Operador:</strong> ${teste.operador}<br>
                <strong>Data:</strong> ${data} ${hora}<br>
                <strong>Status:</strong> <span style="color:green;font-weight:bold">APROVADO ✓</span>
            </div>
            <div style="text-align:center;margin-top:10px;font-size:10px">
                ||||| |||| | |||| ||| ||<br>
                ${teste.serie}
            </div>
        </div>
    `;
    
    zplAtual = gerarZPL(teste);
    document.getElementById('codigoZPL').innerText = zplAtual;
}

function gerarZPL(teste){
    const data = new Date(teste.data).toLocaleDateString('pt-BR');
    const hora = new Date(teste.data).toLocaleTimeString('pt-BR');
    
    return `^XA
^CF0,30
^FO50,30^FDLEITORES PRO^FS
^CF0,25
^FO50,70^FDProduto: ${teste.produtoCodigo}^FS
^FO50,100^FDModelo: ${teste.modelo}^FS
^FO50,130^FDSerie: ${teste.serie}^FS
^FO50,160^FDOperador: ${teste.operador}^FS
^FO50,190^FDData: ${data} ${hora}^FS
^CF0,30
^FO50,230^FDStatus: APROVADO^FS
^BY2,3,50
^FO50,270^BC^FD${teste.serie}^FS
^XZ`;
}

function gerarEtiquetasSelecionadas(){
    if(testesSelecionados.length === 0) return alert('Selecione pelo menos 1 teste');
    
    let zplCompleto = '';
    testesSelecionados.forEach(t => {
        zplCompleto += gerarZPL(t) + '\n\n';
    });
    
    zplAtual = zplCompleto;
    document.getElementById('codigoZPL').innerText = zplCompleto;
    
    if(testesSelecionados.length === 1){
        gerarPreview(testesSelecionados[0]);
    } else {
        document.getElementById('previewEtiqueta').innerHTML = `
            <div class="text-center">
                <i class="bi bi-files" style="font-size:60px;color:#0d6efd"></i>
                <h5 class="mt-3">${testesSelecionados.length} etiquetas prontas</h5>
                <p class="text-muted">Clique em Imprimir ou Baixar ZPL</p>
            </div>`;
    }
}

function imprimirEtiqueta(){
    if(!zplAtual) return alert('Gere uma etiqueta primeiro');
    
    // Abre janela de impressão
    const printWindow = window.open('', '_blank');
    printWindow.document.write(`
        <html>
        <head><title>Imprimir ZPL</title></head>
        <body>
            <h3>Código ZPL para Impressora Zebra</h3>
            <p>Copie o código abaixo e cole no software da impressora Zebra:</p>
            <textarea style="width:100%;height:400px;font-family:monospace">${zplAtual}</textarea>
            <br><br>
            <button onclick="window.print()">Imprimir esta página</button>
        </body>
        </html>
    `);
}

function baixarZPL(){
    if(!zplAtual) return alert('Gere uma etiqueta primeiro');
    
    const blob = new Blob([zplAtual], {type: 'text/plain'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `etiquetas_${Date.now()}.zpl`;
    a.click();
    URL.revokeObjectURL(url);
}
</script>
</body>
</html>
